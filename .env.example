# Copy to .env and fill in real values. Never commit .env.

# --- Tesla Fleet API ---
TESLA_ACCESS_TOKEN=your_token_here
TESLA_REFRESH_TOKEN=
TESLA_VIN=your_vin_here
# Region for Fleet API base URL: na | eu | cn
TESLA_REGION=na
# Optional full override (takes precedence over region)
# TESLA_BASE_URL=https://fleet-api.prd.na.vn.cloud.tesla.com
# Force mock client even with a token set
DEMO_MODE=false

# --- Energy rates (COP per kWh) ---
HOME_ELECTRICITY_RATE=650
SUPERCHARGER_RATE=1300
BATTERY_CAPACITY_KWH=75

# --- Telegram (recommended for family notifications) ---
# Create a bot with @BotFather, then put the token here.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs (your user id and/or family group id)
# Tip: message the bot, then open https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_CHAT_IDS=

# --- WhatsApp Cloud API (optional later) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=tesla-familia-verify
WHATSAPP_RECIPIENTS=+57YOUR_NUMBER

# --- Trip monitor ---
TRIP_POLL_SECONDS=45

# --- Charge reminders ---
CHARGE_LOW_PERCENT=20
CHARGE_REMINDER_TARGET=80
CHARGE_REMINDER_COOLDOWN_MIN=60
